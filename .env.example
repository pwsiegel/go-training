# Firebase web config (public values — safe to commit to a deploy, but kept in
# env so the project can be swapped without code changes). Fill these from the
# Firebase console: Project settings → General → Your apps → SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# GitHub Pages base path for production builds (project site under /<repo>/).
VITE_BASE=/

# Set to "1" to point the app at the local Firebase emulator suite instead of
# live Firebase (see `make app-emulator`). Leave unset for live.
VITE_USE_EMULATOR=

# Set to "1" to show the explore-mode KataGo "AI hints" toggle (local dev only).
# Requires the backend running with the analysis engine: `make api-katago`.
# Leave unset for production builds — there is no engine to reach.
VITE_KATAGO=
